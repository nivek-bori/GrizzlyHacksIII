generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id             String         @id      @default(uuid())
  name           String
  location       String?
  time           DateTime?
  budget         Float
  url            String?
  status         ResourceStatus
  profileId      String
  profile        Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resourceTypeId String
  resourceType   ResourceType   @relation(fields: [resourceTypeId], references: [id], onDelete: Cascade)
}

model ResourceType {
  id        String      @id @default(uuid())
  name      String
  profileId String
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resources Resource[]
}

model Profile {
  id               String             @id @default(uuid())
  role             Role               @default(ADMIN)
  email            String             @unique
  name             String?
  eventDescription EventDescription?
  resourceTypes    ResourceType[]
  resources        Resource[]
}

model EventDescription {
  id         String     @id @default(uuid())
  location   String?
  time       DateTime?
  budget     Float?
  extraNotes String
  profileId  String     @unique
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum ResourceStatus {
  SUGGESTED
  POTENTIAL
  CHOSEN
  BOUGHT
}